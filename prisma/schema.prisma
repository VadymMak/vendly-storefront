generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id                String           @id @default(cuid())
  email             String           @unique
  passwordHash      String?
  name              String?
  uiLanguage        String           @default("sk")
  plan              Plan             @default(FREE)
  stripeAccountId   String?
  aiUsageCount      Int              @default(0)
  aiUsageMonth      String?
  createdAt         DateTime         @default(now())
  aiAdvisorCount    Int              @default(0)
  aiAdvisorLastUsed DateTime?
  aiAdvisorMonth    String?
  studioPaid        Boolean          @default(false)
  stores            Store[]
  studioCredits     StudioCredits?
  studioFeedback    StudioFeedback[]
  studioJobs        StudioJob[]
  apiKeys           UserApiKey[]
}

model UserApiKey {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  encryptedKey String
  keyHint      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Store {
  id           String     @id @default(cuid())
  slug         String     @unique
  customDomain String?    @unique
  templateId   String
  shopLanguage String     @default("sk")
  name         String
  description  String?
  logo         String?
  settings     Json
  isPublished  Boolean    @default(false)
  userId       String
  createdAt    DateTime   @default(now())
  blogPosts    BlogPost[]
  bookings     Booking[]
  items        Item[]
  orders       Order[]
  reviews      Review[]
  user         User       @relation(fields: [userId], references: [id])
}

model Item {
  id          String   @id @default(cuid())
  storeId     String
  type        ItemType
  name        String
  description String?
  price       Float?
  currency    String   @default("EUR")
  category    String?
  images      String[]
  isAvailable Boolean  @default(true)
  sortOrder   Int      @default(0)
  metadata    Json?
  createdAt   DateTime @default(now())
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Order {
  id              String      @id @default(cuid())
  storeId         String
  customerName    String
  customerEmail   String
  customerPhone   String?
  items           Json
  total           Float
  platformFee     Float
  stripeSessionId String?
  status          OrderStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  store           Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Booking {
  id        String        @id @default(cuid())
  storeId   String
  service   String?
  name      String
  phone     String
  email     String?
  datetime  DateTime?
  message   String?
  status    BookingStatus @default(NEW)
  createdAt DateTime      @default(now())
  store     Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Review {
  id          String       @id @default(cuid())
  storeId     String
  author      String
  rating      Int
  text        String
  createdAt   DateTime     @default(now())
  authorEmail String?
  ipAddress   String?
  ownerReply  String?
  status      ReviewStatus @default(PENDING)
  store       Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  content     String
  excerpt     String?
  coverImage  String?
  language    String    @default("sk")
  isPublished Boolean   @default(false)
  storeId     String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  store       Store?    @relation(fields: [storeId], references: [id])
}

model StudioFeedback {
  id             String                 @id @default(cuid())
  userId         String
  userPrompt     String
  enhancedPrompt String
  tool           String
  model          String
  params         Json?
  resultUrl      String?
  rating         String
  issue          String?
  createdAt      DateTime               @default(now())
  embedding      Unsupported("vector")?
  category       String?
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tool])
  @@index([rating])
  @@index([userId])
  @@index([embedding])
}

model AiUsage {
  id        String   @id @default(cuid())
  userId    String
  action    String
  month     String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, month])
}

model Lead {
  id                 String    @id @default(cuid())
  businessType       String
  services           String
  contact            String
  language           String
  demoUrl            String?
  status             String    @default("new")
  notes              String?
  siteUrl            String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  businessName       String?
  contactName        String?
  customDomain       String?
  email              String?
  githubRepo         String?
  nextPaymentDate    DateTime?
  package            String?
  paidOneTime        Boolean   @default(false)
  paidOneTimeDate    DateTime?
  priceMonthly       Float?
  priceOneTime       Float?
  templateUsed       String?
  vercelProject      String?
  address            String?
  briefSubmitted     Boolean   @default(false)
  briefSubmittedAt   DateTime?
  logoUrl            String?
  photoUrls          String?
  priceListUrl       String?
  referenceUrl       String?
  selectedHero       String?
  selectedMood       String?
  selectedPalette    String?
  socialFacebook     String?
  socialInstagram    String?
  wishes             String?
  workingHours       String?
  briefServicesJson  String?
  siteCreatedAt      DateTime?
  siteError          String?
  siteQaReport       String?
  siteRepoName       String?
  siteRepoUrl        String?
  siteStatus         String?   @default("none")
  siteVercelUrl      String?
  heroImageIndex     Int?
  description        String?
  galleryUrls        String[]
  heroPhotoUrl       String?
  plan               String?
  photos             Json?
  heroLayout         String?
  ownerFullName      String?
  companyLegalForm   String?
  vatId              String?
  registrationNumber String?
  impressumEmail     String?
}

model StudioCredits {
  id                    String    @id @default(cuid())
  userId                String    @unique
  monthlyImages         Int       @default(5)
  monthlyVideos         Int       @default(1)
  bonusImages           Int       @default(0)
  bonusVideos           Int       @default(0)
  lastReset             DateTime  @default(now())
  planType              String    @default("free")
  byokEnabled           Boolean   @default(false)
  replicateKey          String?
  totalGeneratedImages  Int       @default(0)
  totalGeneratedVideos  Int       @default(0)
  phoneVerified         Boolean   @default(false)
  phoneNumber           String?   @unique
  existingUserMigration Boolean   @default(false)
  migrationExpiresAt    DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudioJob {
  id             String   @id @default(cuid())
  userId         String
  predictionId   String   @unique
  type           String
  status         String   @default("starting")
  outputUrl      String?
  error          String?
  creditType     String?
  creditAmount   Int      @default(1)
  creditDeducted Boolean  @default(false)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
}

enum Plan {
  FREE
  STARTER
  PRO
}

enum ItemType {
  PRODUCT
  SERVICE
  MENU_ITEM
  PORTFOLIO
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  NEW
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  REJECTED
}
